<?xml version="1.0" encoding="utf-8" ?>
<templates xml:space="preserve">
    <t t-name="real_state.FormView">
        <div class="p-3">
            <div class="o_field_widget mb-3">
                <label class="o_form_label">Name</label>
                <input class="o_input form_control" t-model="state.name" placeholder="Enter property Name"/>
            </div>
            <div class="o_field_widget mb-3">
                <label class="o_form_label">Postcode</label>
                <input class="o_input form_control" t-model="state.postcode" placeholder="Enter property Postcode"/>
            </div>
            <div class="o_field_widget mb-3">
                <label class="o_form_label">Date Availability</label>
                <input class="o_input form_control" t-model="state.date_availability" type="date" placeholder="Enter property Date Availability"/>
            </div>
            <div class="footer">
                <button class="btn btn-primary me-2" t-on-click="this.createRecord">Save</button>
                <button class="btn btn-secondary" t-on-click="this.cancel">Cancel</button>
            </div>
        </div>
    </t>
</templates>