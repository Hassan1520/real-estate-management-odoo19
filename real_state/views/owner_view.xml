<odoo>
    <data>
        <record id="owner_list_view" model="ir.ui.view">
            <field name="name">owner list view</field>
            <field name="model">owner</field>
            <field name="arch" type="xml">
                <list multi_edit="1" create="1" edit="1" delete="1">
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="address"/>
                </list>
            </field>
        </record>
        <record id="owner_view_form" model="ir.ui.view">
            <field name="name">owner form view</field>
            <field name="model">owner</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="General Info">
                                <field name="phone"/>
                                <field name="address"/>
                            </group>
                            <group string="Properties">
                                <field name="property_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="owner_search_view" model="ir.ui.view">
            <field name="name">owner search view</field>
            <field name="model">owner</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>
        <record id="owner_action" model="ir.actions.act_window">
            <field name="name">Owner</field>
            <field name="res_model">owner</field>
        </record>
        <menuitem id="owner_menu_item" name="Owner" parent="configuration_menu" action="owner_action"/>
    </data>
</odoo>