<odoo>
    <data>
        <record id="property_view_list" model="ir.ui.view">
            <field name="name">property list view</field>
            <field name="model">property</field>
            <field name="arch" type="xml">
                <list multi_edit="1" create="1" edit="1" delete="1" class="header_custom" decoration-danger="is_late">
                    <header>
                        <button name="property_xlsx_report" type="object" string="Excel Report" class="btn-primary"/>
                    </header>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="owner_id"/>
                    <field name="postcode"/>
                    <field name="is_late" invisible="1"/>
                    <field name="date_availability"/>
                    <field name="facades"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'pending'" decoration-success="state == 'sold'"/>
                    <field name="garden_area"/>
                    <field name="bedrooms" optional="1"/>
                    <field name="garden" optional="1"/>
                    <field name="active" optional="1"/>
                </list>
            </field>
        </record>

        <record id="property_view_form" model="ir.ui.view">
            <field name="name">property form view</field>
            <field name="model">property</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_draft" type="object" class="btn-primary" string="Set to Draft" invisible="state in ('draft', 'closed')"/>
                        <button name="action_pending" type="object" class="btn-secondary" string="Pending" invisible="state != 'draft'"/>
                        <button name="action_sold" type="object" class="btn-success" string="Sold" invisible="state != 'pending'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div name="button_box" class="oe_button_box">
                            <button name="action_open_related_owner" type="object" icon="fa-user" string="Owner" invisible="not owner_id"/>
                        </div>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <widget name="web_ribbon" title="Sold" bg_color="text-bg-success" invisible="state != 'sold'"/>
                        <div class="oe_title">
                            <label for="ref"/>
                            <h1><field name="ref"/></h1>
                            <label for="name"/>
                            <h3><field name="name" readonly="state == 'closed'"/></h3>
                        </div>
                        <group>
                            <group string="General Info">
                                <field name="create_time"/>
                                <field name="next_time"/>
                                <field name="description"/>
                                <field name="expected_selling_date"/>
                                <field name="is_late"/>
                                <field name="expected_price"/>
                                <field name="selling_price"/>
                                <field name="diff"/>
                                <field name="postcode"/>
                                <field name="date_availability"/>
                            </group>
                            <group string="Additional Info">
                                <field name="facades"/>
                                <field name="owner_id"/>
                                <field name="owner_address"/>
                                <field name="owner_phone"/>
                                <field name="garden_area"/>
                                <field name="bedrooms"/>
                                <field name="garden"/>
                                <field name="active"/>
                                <field name="tag_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lines">
                                <field name="line_ids">
                                    <list editable="bottom" multi_edit="1">
                                        <field name="description"/>
                                        <field name="area"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="property_search_view" model="ir.ui.view">
            <field name="name">property search view</field>
            <field name="model">property</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="postcode"/>
                    <filter name="is_garden" string="With Garden" domain="[('garden', '=', True)]"/>
                    <filter name="group_garden" string="Garden" context="{'group_by': 'garden'}"/>
                </search>
            </field>
        </record>

        <record id="property_action" model="ir.actions.act_window">
            <field name="name">Property</field>
            <field name="res_model">property</field>
        </record>

        <record id="property_closed_server_action" model="ir.actions.server">
            <field name="name">Closed</field>
            <field name="model_id" ref="model_property"/>
            <field name="binding_model_id" ref="model_property"/>
            <field name="state">code</field>
            <field name="code">records.action_closed()</field>
        </record>

        <record id="property_change_state_server_action" model="ir.actions.server">
            <field name="name">Change State</field>
            <field name="model_id" ref="model_property"/>
            <field name="binding_model_id" ref="model_property"/>
            <field name="state">code</field>
            <field name="code">action = records.action_open_change_state_wizard()</field>
        </record>

        <record id="check_selling_date_cron" model="ir.cron">
            <field name="name">Property: Check Selling Date</field>
            <field name="model_id" ref="model_property"/>
            <field name="state">code</field>
            <field name="code">model.check_expected_selling_date()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <menuitem id="property_menu_item" name="Properties" parent="property_menu" action="property_action"/>

        <record id="list_view_action" model="ir.actions.client">
            <field name="name">Property List View</field>
            <field name="tag">real_state.action_list_view</field>
        </record>
        <menuitem id="property_list_view_menu_item" name="Properties Owl" parent="property_menu" action="list_view_action"/>
    </data>
</odoo>