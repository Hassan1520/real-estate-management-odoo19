<odoo>
    <data>
        <record id="property_history_list_view" model="ir.ui.view">
            <field name="name">property history list view</field>
            <field name="model">property.history</field>
            <field name="arch" type="xml">
                <list create="0" edit="0" delete="0">
                    <field name="user_id"/>
                    <field name="property_id"/>
                    <field name="old_state"/>
                    <field name="new_state"/>
                </list>
            </field>
        </record>
        <record id="property_history_list_form" model="ir.ui.view">
            <field name="name">property history form view</field>
            <field name="model">property.history</field>
            <field name="arch" type="xml">
                <form create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="user_id"/>
                                <field name="property_id"/>
                            </group>
                            <group>
                                <field name="new_state"/>
                                <field name="old_state"/>
                                <field name="reason"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="History Lines">
                                <field name="line_ids" readonly="1">
                                    <list>
                                        <field name="description"/>
                                        <field name="area"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="property_history_action" model="ir.actions.act_window">
            <field name="name">Property History</field>
            <field name="res_model">property.history</field>
        </record>

        <menuitem id="property_history_menu_item" name="History" parent="property_menu" action="property_history_action"/>
    </data>
</odoo>