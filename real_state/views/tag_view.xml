<odoo>
    <data>
        <record id="tag_list_view" model="ir.ui.view">
            <field name="name">tag list view</field>
            <field name="model">tag</field>
            <field name="arch" type="xml">
                <list multi_edit="1" create="1" edit="1" delete="1">
                    <field name="name"/>
                </list>
            </field>
        </record>
        <record id="tag_view_form" model="ir.ui.view">
            <field name="name">tag form view</field>
            <field name="model">tag</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name"/></h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="tag_search_view" model="ir.ui.view">
            <field name="name">tag search view</field>
            <field name="model">tag</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>
        <record id="tag_action" model="ir.actions.act_window">
            <field name="name">Tag</field>
            <field name="res_model">tag</field>
        </record>
        <menuitem id="tag_menu_item" name="Tag" parent="configuration_menu" action="tag_action"/>
    </data>
</odoo>