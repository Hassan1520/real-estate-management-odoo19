<odoo>
    <record id="property_report" model="ir.actions.report">
        <field name="name">Property Report</field>
        <field name="model">property</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real_state.property_report_template</field>
        <field name="report_file">real_state.property_report_template</field>
        <field name="binding_model_id" ref="model_property"/>
        <field name="binding_type">report</field>
    </record>
    <template id="property_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="property">
                    <div class="page">
                        <h2>Property Report</h2>
                        <table class="table table-sm">
                            <tr>
                                <th>Property Name</th>
                                <td><t t-esc="property.name"/></td>
                                <th>Postcode</th>
                                <td><t t-esc="property.postcode"/></td>
                            </tr>
                            <tr>
                                <th>Owner</th>
                                <td><t t-esc="property.owner_id.name or ''"/></td>
                                <th>Phone</th>
                                <td><t t-esc="property.owner_phone or ''"/></td>
                            </tr>
                        </table>
                        <br/>
                        <h4>Additional Lines</h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th>Area</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="property.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.description"/></td>
                                        <td><t t-esc="line.area"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>